<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Food" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:statusBarColor">@color/app_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorSurface">@color/app_card_bg</item>
        <item name="colorOnSurface">@color/app_text_primary</item>
        
        <item name="android:editTextColor">@color/app_text_primary</item>
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>
        <item name="android:textColorHint">@color/app_text_secondary</item>
    </style>

    <style name="Theme.Food" parent="Base.Theme.Food" />

    <style name="FigmaButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/app_primary</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="shapeAppearanceOverlay">@style/RoundedShape</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="RoundedButton" parent="FigmaButton" />

    <style name="FigmaCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/app_card_bg</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">6dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="RoundedShape">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="TitleText">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="SectionText">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BodyText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/app_text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>