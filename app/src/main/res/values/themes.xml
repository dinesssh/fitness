<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Food" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="android:windowBackground">@color/background_white</item>
        <item name="android:statusBarColor">@color/background_white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Food" parent="Base.Theme.Food" />

    <style name="FigmaButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_orange</item>
        <item name="backgroundTint">@null</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <style name="FigmaCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="TitleText">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dark</item>
    </style>

    <style name="SectionText">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dark</item>
    </style>

    <style name="BodyText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_grey</item>
    </style>
</resources>