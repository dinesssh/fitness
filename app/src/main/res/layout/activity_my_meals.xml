<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/circle_outline"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/dashboardTitle"
                style="@style/TitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="My Daily Progress"
                app:layout_constraintBottom_toBottomOf="@id/backButton"
                app:layout_constraintStart_toEndOf="@id/backButton"
                app:layout_constraintTop_toTopOf="@id/backButton" />

            <!-- Calorie Goal Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/calorieCard"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/dashboardTitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCaloriesValue"
                        style="@style/TitleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 2000 kcal"
                        android:textSize="28sp" />

                    <ProgressBar
                        android:id="@+id/pbCalories"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="12dp"
                        android:progress="0"
                        android:max="2000" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Macro Progress -->
            <LinearLayout
                android:id="@+id/macroRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/calorieCard">

                <include layout="@layout/indicator_macro_vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                <include layout="@layout/indicator_macro_vertical_fats" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                <include layout="@layout/indicator_macro_vertical_carbs" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            </LinearLayout>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/nutritionButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:text="Log New Meal"
                app:layout_constraintTop_toBottomOf="@id/macroRow" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/hydrationButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:text="Add Water intake"
                app:layout_constraintTop_toBottomOf="@id/nutritionButton" />

            <!-- Meal History Title -->
            <TextView
                android:id="@+id/historyTitle"
                style="@style/SectionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="Recent Meals"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/hydrationButton" />

            <!-- Using a simple ListView placeholder as we're avoiding Fragments/Complex adapters if not needed, 
                 but user asked for RecyclerView. I will implement a simple vertical layout for meals. -->
            <LinearLayout
                android:id="@+id/mealListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/historyTitle" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nearbyFoodButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:text="Find Healthy Food Nearby"
                app:layout_constraintTop_toBottomOf="@id/mealListContainer" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareReportButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:text="Share Diet Report"
                app:layout_constraintTop_toBottomOf="@id/nearbyFoodButton" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>