<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/circle_outline"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/dashboardTitle"
                style="@style/TitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="My Meals"
                app:layout_constraintBottom_toBottomOf="@id/backButton"
                app:layout_constraintStart_toEndOf="@id/backButton"
                app:layout_constraintTop_toTopOf="@id/backButton" />

            <HorizontalScrollView
                android:id="@+id/dateSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/backButton">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">
                    <include layout="@layout/item_date" />
                    <include layout="@layout/item_date_active" />
                    <include layout="@layout/item_date" />
                    <include layout="@layout/item_date" />
                </LinearLayout>
            </HorizontalScrollView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mealCard"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/dateSelector">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/calorieLabel"
                        style="@style/BodyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="294 kcal - 100g"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/calorieLabel">
                        <include layout="@layout/indicator_macro_vertical" />
                        <Space android:layout_width="24dp" android:layout_height="wrap_content"/>
                        <include layout="@layout/indicator_macro_vertical_fats" />
                        <Space android:layout_width="24dp" android:layout_height="wrap_content"/>
                        <include layout="@layout/indicator_macro_vertical_carbs" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nearbyFoodButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:text="Find Healthy Food Nearby"
                app:layout_constraintTop_toBottomOf="@id/mealCard" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nutritionButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:text="Nutrition Detail"
                app:layout_constraintTop_toBottomOf="@id/nearbyFoodButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/statsButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:text="Calorie Stats"
                app:layout_constraintTop_toBottomOf="@id/nutritionButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/hydrationButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:text="Hydration Tracker"
                app:layout_constraintTop_toBottomOf="@id/statsButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareReportButton"
                style="@style/FigmaButton"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:text="Share SMS Diet Report"
                app:layout_constraintTop_toBottomOf="@id/hydrationButton" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>