<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gh_bg"
    android:padding="20dp">

    <TextView
        android:id="@+id/selectionTitle"
        style="@style/TitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Your Workout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/selectionSubtitle"
        style="@style/BodyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select a mini-gym themed session"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/selectionTitle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/selectionSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Chest Day -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChestDay"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥 Chest Day" android:textColor="@color/gh_text" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bench Press, Flyes, Pushups" android:textColor="@color/gh_text_muted" android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Back Day -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBackDay"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⛰️ Back Day" android:textColor="@color/gh_text" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Deadlifts, Rows, Pullups" android:textColor="@color/gh_text_muted" android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Arm Day -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardArmDay"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💪 Arm Day" android:textColor="@color/gh_text" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bicep Curls, Skull Crushers" android:textColor="@color/gh_text_muted" android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Leg Day -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLegDay"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍗 Leg Day" android:textColor="@color/gh_text" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Squats, Lunges, Calf Raises" android:textColor="@color/gh_text_muted" android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Shoulder Day -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardShoulderDay"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛡️ Shoulder Day" android:textColor="@color/gh_text" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Overhead Press, Lateral Raises" android:textColor="@color/gh_text_muted" android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cardio Day -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCardio"
                style="@style/FigmaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏃 Cardio" android:textColor="@color/gh_text" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Running, Jump Rope, Cycling" android:textColor="@color/gh_text_muted" android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>